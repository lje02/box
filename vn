#!/bin/bash
# VPS 管理面板主控 

ORIG_ARGS=("$@")

COMMON_PATH="/usr/local/share/vn_modules/common.sh"
if [ -z "$VPS_COMMON_LOADED" ]; then
    if [ -f "$COMMON_PATH" ]; then
        source "$COMMON_PATH"
    else
        echo "错误：找不到公共库 $COMMON_PATH"
        exit 1
    fi
fi

check_root
detect_os
check_dependencies

MODULE_DIR="/usr/local/share/vn_modules"
# 补充主控自身的真实下载地址变量
GITHUB_RAW_URL="https://raw.githubusercontent.com/lje02/vp/main/vn"

# 所有模块列表（新增模块只需在此数组中添加名称）
MODULES_LIST=(
    "firewall_fail2ban.sh"
    "system_optimize.sh"
    "remote_jump.sh"
    "singbox.sh"
    "monitor.sh"
    "ssh_harden.sh"
    "traffic_monitor.sh"
    "logs.sh"
    "tgbot.sh"
    "backups.sh"
    "tg_si.sh"
    "huanjing.sh"
    "photo.sh"

)

# ----------------- 自安装（安装后自动更新） -----------------
update_all() {
    local silent_mode=false
    [ "$1" = "--silent" ] && silent_mode=true

    local base_url="https://raw.githubusercontent.com/lje02/vp/main/modules"
    local updated=0
    local spin='-\|/'
    local idx=0

    # 1. 确保模块存储目录存在，防止 mv 报错
    [ -n "$MODULE_DIR" ] && mkdir -p "$MODULE_DIR" 2>/dev/null

    # ---- 模块更新 ----
    $silent_mode || printf "同步模块中 "
    for mod in "${MODULES_LIST[@]}"; do
        local tmp="/tmp/${mod}.new"
        if curl -fsSL "$base_url/$mod" -o "$tmp" 2>/dev/null; then
            if [ -s "$tmp" ]; then
                if [ -f "$MODULE_DIR/$mod" ] && diff "$MODULE_DIR/$mod" "$tmp" &>/dev/null; then
                    rm -f "$tmp"
                else
                    mv "$tmp" "$MODULE_DIR/$mod"
                    chmod +x "$MODULE_DIR/$mod"
                    ((updated++))
                fi
            else
                rm -f "$tmp"
            fi
        fi
        $silent_mode || printf "\b${spin:$((idx%4)):1}"
        ((idx++))
    done
    $silent_mode || printf "\b√\n"

    # ---- 公共库更新 ----
    local tmp_common="/tmp/common.sh.new"
    local common_url="https://raw.githubusercontent.com/lje02/vp/main/common.sh"
    if curl -fsSL "$common_url" -o "$tmp_common" 2>/dev/null; then
        if [ -s "$tmp_common" ]; then
            if [ -f "$MODULE_DIR/common.sh" ] && diff "$MODULE_DIR/common.sh" "$tmp_common" &>/dev/null; then
                rm -f "$tmp_common"
            else
                mv "$tmp_common" "$MODULE_DIR/common.sh"
                ((updated++))
            fi
        else
            rm -f "$tmp_common"
        fi
    fi

    if [ "$updated" -gt 0 ]; then
        printf "${GREEN}共更新 %d 个文件。${NC}\n" "$updated"
    elif ! $silent_mode; then
        printf "${GREEN}所有模块均为最新。${NC}\n"
    fi

    # ---- 主控更新 ----
    $silent_mode || printf "${BLUE}检查主控更新...${NC}\n"
    local tmpfile="/tmp/vn_latest.sh"
    if curl -fsSL "$GITHUB_RAW_URL" -o "$tmpfile" 2>/dev/null; then
        if [ -s "$tmpfile" ]; then
            local real_script
            real_script=$(realpath "$0" 2>/dev/null || readlink -f "$0" 2>/dev/null || echo "$0")
            if ! diff "$real_script" "$tmpfile" &>/dev/null; then
                chmod +x "$tmpfile"
                mv -f "$tmpfile" "$real_script"
                $silent_mode || printf "${GREEN}主控已更新，重新加载...${NC}\n"
                
                exec "$real_script" "${ORIG_ARGS[@]}"
            else
                $silent_mode || printf "${GREEN}主控已是最新。${NC}\n"
                rm -f "$tmpfile"
            fi
        else
            $silent_mode || printf "${RED}主控下载异常 (文件为空)。${NC}\n"
            rm -f "$tmpfile"
        fi
    else
        $silent_mode || printf "${RED}主控更新下载失败。${NC}\n"
        rm -f "$tmpfile"
    fi
    echo ""
    read -p "按回车键继续...多更新两次" dummy
}

# ----------------- 卸载 -----------------
uninstall_script() {
    read -p "确定要卸载此管理面板吗？此操作不可恢复！[y/N] " confirm
    [[ ! $confirm =~ ^[Yy]$ ]] && return
    local script_path=$(realpath "$0" 2>/dev/null || readlink -f "$0" 2>/dev/null || echo "$0")
    rm -f "$script_path" /usr/local/bin/vn 2>/dev/null
    rm -rf "$MODULE_DIR"
    printf "${GREEN}卸载完成。${NC}\n"
    exit 0
}

# ----------------- 运行模块 -----------------
run_module() {
    local mod_path="$MODULE_DIR/$1"
    if [ -f "$mod_path" ]; then
        bash "$mod_path"
    else
        printf "${RED}模块 $1 缺失，请执行更新（菜单 u）获取。${NC}\n"
        read -p "按回车键继续..." dummy
    fi
}

# ----------------- 自安装 -----------------
install_self() {
    local install_path="/usr/local/bin/vn"
    if [[ "$1" == "--install" ]]; then
        ln -sf "$(realpath "$0")" "$install_path"
        chmod +x "$install_path"
        printf "${GREEN}✔ 安装成功！现在输入 'vn' 即可启动面板。${PLAIN}\n"
        exit 0
    fi
}

# ----------------- 主菜单 -----------------
main_menu() {
    while true; do
        clear
        echo -e "--------------------------------------------"
        printf "${GREEN}========== VPS 综合管理面板 (vn) ==========${PLAIN}\n"
        echo -e "--------------------------------------------"
        echo -e " 1. 防火墙 / Fail2Ban 管理"
        echo -e " 2. 系统信息与优化 (BBR/Swap)"
        echo -e " 3. sing-box 管理"
        echo -e " 4. 系统实时监控"
        echo -e " 5. 流量统计"
        echo -e " 6. 日志查看/分析"
        echo -e " 7. 密钥生成/禁用密码"
        echo -e " 8. 远程SSH跳转(输入exit退出)"
        echo -e " 9. Telegram 系统监控"
        echo -e "10. Telegram 私聊bot"
        echo -e "11. 环境搭建"
        echo -e "12. photos"
        echo -e "13. 备份/还原"
        echo -e "--------------------------------------------"
        echo -e "u. 更新全部       x. 卸载       0. 退出"
        echo -e "--------------------------------------------"
        read -p "请输入选项: " main_choice

        case "$main_choice" in
            1) run_module "firewall_fail2ban.sh" ;;
            2) run_module "system_optimize.sh" ;;
            3) run_module "singbox.sh" ;;
            4) run_module "monitor.sh" ;;
            5) run_module "traffic_monitor.sh" ;;
            6) run_module "logs.sh" ;;
            7) run_module "ssh_harden.sh" ;;
            8) run_module "remote_jump.sh" ;;
            9) run_module "tgbot.sh" ;;
            10) run_module "tg_si.sh" ;;
            11) run_module "huanjing.sh" ;;
            12) run_module "photo.sh" ;;
            13) run_module "backups.sh" ;;
            u) update_all ;;
            x) uninstall_script ;;
            0) exit 0 ;;
            *) printf "${RED}无效选项${NC}\n" && sleep 1 ;;
        esac
    done
}

# ---------- 启动 ----------
install_self "${ORIG_ARGS[0]}" # 这里也可以直接传 ${ORIG_ARGS[@]}，具体看 common.sh 里 install_self 的逻辑
main_menu
