#!/bin/bash
# VPS 管理面板主控 (vp)

COMMON_PATH="/usr/local/share/vp_modules/common.sh"
if [ -z "$VPS_COMMON_LOADED" ]; then
    if [ -f "$COMMON_PATH" ]; then
        source "$COMMON_PATH"
    else
        echo "错误：找不到公共库 $COMMON_PATH"
        exit 1
    fi
fi

check_root
detect_os
check_dependencies

MODULE_DIR="/usr/local/share/vp_modules"

# 所有模块列表（新增模块只需在此数组中添加名称）
MODULES_LIST=(
    "firewall_fail2ban.sh"
    "system_optimize.sh"
    "remote_jump.sh"
    "singbox.sh"
    "monitor.sh"
    "ssh_harden.sh"
    "traffic_monitor.sh"
    "logs.sh"
    "tg_monitor.sh"
)

# ----------------- 自安装（安装后自动更新） -----------------
install_self() {
    local install_path="/usr/local/bin/vp"
    if [[ "$1" == "--install" ]]; then
        ln -sf "$(realpath "$0")" "$install_path"
        chmod +x "$install_path"
        printf "${GREEN}✔ 主控安装成功！${NC}\n"
        # 自动执行一次全量更新，拉取所有模块
        printf "${BLUE}▶ 同步所有模块...${NC}\n"
        update_all --silent
        printf "${GREEN}✔ 所有模块已同步。${NC}\n"
        printf "${GREEN}现在输入 'vp' 即可启动管理面板。${NC}\n"
        exit 0
    fi
}

# ----------------- 全量更新（主控 + 模块+公共库） -----------------
update_all() {
    local silent_mode=false
    [ "$1" = "--silent" ] && silent_mode=true

    # 1. 更新主控脚本
    printf "${BLUE}检查主控更新...${NC}\n"
    local tmpfile="/tmp/vp_latest.sh"
    if curl -sL "$GITHUB_RAW_URL" -o "$tmpfile"; then
        local real_script
        real_script=$(realpath "$0" 2>/dev/null || readlink -f "$0" 2>/dev/null || echo "$0")
        if ! diff "$real_script" "$tmpfile" &>/dev/null; then
            chmod +x "$tmpfile"
            mv "$tmpfile" "$real_script"
            printf "${GREEN}主控已更新，重新加载...${NC}\n"
            exec "$real_script" "$@"
        else
            printf "${GREEN}主控已是最新。${NC}\n"
            rm -f "$tmpfile"
        fi
    else
        $silent_mode || printf "${RED}主控更新下载失败。${NC}\n"
    fi

    # 2. 更新所有模块
    local base_url="https://raw.githubusercontent.com/lje02/vp/main/modules"
    local updated=0
    for mod in "${MODULES_LIST[@]}"; do
        $silent_mode || printf "检查 %s ... " "$mod"
        local tmp="/tmp/${mod}.new"
        if curl -sSL "$base_url/$mod" -o "$tmp"; then
            if [ -f "$MODULE_DIR/$mod" ] && diff "$MODULE_DIR/$mod" "$tmp" &>/dev/null; then
                $silent_mode || printf "${GREEN}已是最新${NC}\n"
            else
                mv "$tmp" "$MODULE_DIR/$mod"
                chmod +x "$MODULE_DIR/$mod"
                $silent_mode || printf "${YELLOW}已更新${NC}\n"
                ((updated++))
            fi
        else
            $silent_mode || printf "${RED}下载失败${NC}\n"
            [ -f "$tmp" ] && rm -f "$tmp"
        fi
    done

    # 3. 额外更新公共库 common.sh
    $silent_mode || printf "检查公共库 common.sh ... "
    local tmp_common="/tmp/common.sh.new"
    local common_url="https://raw.githubusercontent.com/lje02/vp/main/common.sh"
    if curl -sSL "$common_url" -o "$tmp_common"; then
        if [ -f "$MODULE_DIR/common.sh" ] && diff "$MODULE_DIR/common.sh" "$tmp_common" &>/dev/null; then
            $silent_mode || printf "${GREEN}已是最新${NC}\n"
        else
            mv "$tmp_common" "$MODULE_DIR/common.sh"
            $silent_mode || printf "${YELLOW}已更新（下次运行 vp 生效）${NC}\n"
            ((updated++))
        fi
    else
        $silent_mode || printf "${RED}下载失败${NC}\n"
        [ -f "$tmp_common" ] && rm -f "$tmp_common"
    fi

    [ $updated -gt 0 ] && printf "${GREEN}共更新 %d 个文件。${NC}\n" $updated || true
}

# ----------------- 卸载 -----------------
uninstall_script() {
    read -p "确定要卸载此管理面板吗？此操作不可恢复！[y/N] " confirm
    [[ ! $confirm =~ ^[Yy]$ ]] && return
    local script_path=$(realpath "$0" 2>/dev/null || readlink -f "$0" 2>/dev/null || echo "$0")
    rm -f "$script_path" /usr/local/bin/vp 2>/dev/null
    rm -rf "$MODULE_DIR"
    printf "${GREEN}卸载完成。${NC}\n"
    exit 0
}

# ----------------- 运行模块 -----------------
run_module() {
    local mod_path="$MODULE_DIR/$1"
    if [ -f "$mod_path" ]; then
        bash "$mod_path"
    else
        printf "${RED}模块 $1 缺失，请执行更新（菜单 u）获取。${NC}\n"
        read -p "按回车键继续..." dummy
    fi
}

# ----------------- 主菜单 -----------------
main_menu() {
    while true; do
        clear
        echo -e "--------------------------------------------"
        printf "${GREEN}========== VPS 综合管理面板 (vp) ==========${PLAIN}\n"
        echo -e "--------------------------------------------"
        echo -e "1. 防火墙 / Fail2Ban 管理"
        echo -e "2. 系统信息与优化 (BBR/Swap)"
        echo -e "3. sing-box 管理"
        echo -e "4. 系统实时监控"
        echo -e "5. 流量统计"
        echo -e "6. 日志查看/分析"
        echo -e "7. 密钥生成/禁用密码"
        echo -e "8. 远程SSH跳转(输入exit退出)"
        echo -e "9. Telegram 远程监控"
        echo -e "--------------------------------------------"
        echo -e "u. 更新全部 (主控+模块)   x. 卸载   0. 退出"
        echo -e "--------------------------------------------"
        read -p "请输入选项: " main_choice

        case "$main_choice" in
            1) run_module "firewall_fail2ban.sh" ;;
            2) run_module "system_optimize.sh" ;;
            3) run_module "singbox.sh" ;;
            4) run_module "monitor.sh" ;;
            5) run_module "traffic_monitor.sh" ;;
            6) run_module "logs.sh" ;;
            7) run_module "ssh_harden.sh" ;;
            8) run_module "remote_jump.sh" ;;
            9) run_module "tg_monitor.sh" ;;
            u) update_all ;;
            x) uninstall_script ;;
            0) exit 0 ;;
            *) printf "${RED}无效选项${NC}\n" && sleep 1 ;;
        esac
    done
}

# ---------- 启动 ----------
install_self "$1"
main_menu
